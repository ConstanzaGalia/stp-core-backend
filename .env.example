# Copiar a .env y completar valores reales.

# --- Base de datos (Postgres) ---
#
# Nest + TypeORM ya usan un pool de `pg` por instancia del API (equivalente al singleton del tip).
# No hace falta crear `new Pool()` en otro archivo salvo consultas SQL crudas aparte.
#
# Producción (Railway, Render, Fly, etc.): suele venir solo DATABASE_URL.
# Si DATABASE_URL está definida, se usa y se ignoran DB_HOST / DB_PORT / DB_* abajo.
# DATABASE_URL=postgresql://user:pass@host:5432/dbname?sslmode=require
#
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=
DB_PASSWORD=
DB_NAME=
# true para la mayoría de hosts en la nube (ignorado en parte si el SSL va en DATABASE_URL)
DB_SSL=true

# Tamaño máximo del pool por proceso Node (TypeORM → driver pg).
# Límite efectivo ≈ (réplicas del API) × max del pool.
#
# Supabase — error "MaxClientsInSessionMode":
# - El pooler en modo Session (host …pooler.supabase.com, puerto 5432) admite pocos clientes.
# - El código aplica tope 4 en ese caso; si igual falla, bajá DB_POOL_MAX a 2 o reducí réplicas.
# - Mejor: en Supabase → Database → Connection string, elegí "Transaction pooler" (puerto 6543)
#   en DATABASE_URL; ahí podés subir DB_POOL_MAX con más margen.
#
# Default en código si no se define: 5 (y máx. 4 si detecta Supabase Session pooler)
DB_POOL_MAX=5

# Opcionales (timeouts del pool en ms; defaults en app.module: 60000 / 30000)
# DB_CONNECTION_TIMEOUT_MS=60000
# DB_IDLE_TIMEOUT_MS=30000

# --- App ---
NODE_ENV=development
PORT=3000
# URL pública del front (CORS, redirects OAuth, enlaces en mails). Next.js `next dev` usa 3000 por defecto:
# si el API también corre en 3000, cambiá PORT o el puerto del front.
FRONTEND_URL=http://localhost:3000
# JWT (obligatorio para auth)
SECRET_JWT=
# Duración del access token (ej. 30d, 7d, 12h). Debe alinearse con la expiración de cookies en el front.
JWT_EXPIRES_IN=30d
# Enlace de reset de contraseña en mail: se arma como `${HOST}${PORT}/auth/reset-password?token=...`
# Ej.: HOST=http://localhost:  (con dos puntos; el PORT del API se concatena después)
HOST=http://localhost:

# Base URL del API para links en respuestas paginadas (pagination). Si queda vacío, los links relativos pueden quedar mal.
URL_BASE=http://localhost:3000

# --- Email (Resend) ---
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# --- OAuth Google (opcional; si no usás Google login, podés omitir) ---
# GOOGLE_CLIENT_ID=
# GOOGLE_SECRET=
# CALLBACK_URL_GOOGLE=

# --- IA — análisis de evaluaciones físicas (Anthropic) ---
# Sin ANTHROPIC_API_KEY el flujo de IA no funcionará.
ANTHROPIC_API_KEY=
# Opcional; default en código: claude-opus-4-6
# ANTHROPIC_AI_MODEL=claude-opus-4-6

# --- Subida de archivos de evaluaciones (PDF/CSV, etc.) ---
# Directorio: absoluto o relativo al cwd del proceso. Default: uploads/evaluations
# EVALUATIONS_UPLOAD_DIR=uploads/evaluations
# Tamaño máximo por archivo en MB. Default: 25
# EVALUATIONS_MAX_FILE_MB=25

# --- Centro operativo STP (STP_ADMIN) ---
# UUID del centro madre STP. Default en código si no se define.
# STP_OPERATING_COMPANY_ID=7623d786-23a5-447b-b970-bb58ee2a70ac

# --- Scripts (no requeridos para el API en runtime) ---
# COMPANY_ID=   # seed-horarios-fijos.ts
