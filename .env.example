# Copiar a .env y completar valores reales.

# --- Base de datos (Postgres) ---
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=
DB_PASSWORD=
DB_NAME=
# true para la mayoría de hosts en la nube
DB_SSL=true

# Tamaño máximo del pool de conexiones por proceso Node (pg).
# Con poolers en modo Session (p. ej. Supabase) el límite de clientes suele ser bajo;
# si tenés varias instancias del API, cada una abre hasta `DB_POOL_MAX` conexiones.
# Si ves "MaxClientsInSessionMode", bajá este valor o reducí réplicas.
# Default en código si no se define: 8
DB_POOL_MAX=8

# Opcionales (timeouts del pool en ms)
# DB_CONNECTION_TIMEOUT_MS=60000
# DB_IDLE_TIMEOUT_MS=30000

# --- App ---
PORT=3000
FRONTEND_URL=http://localhost:3000
SECRET_JWT=

# --- Email (Resend) ---
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# --- OAuth Google (si aplica) ---
# GOOGLE_CLIENT_ID=
# GOOGLE_SECRET=
# CALLBACK_URL_GOOGLE=
